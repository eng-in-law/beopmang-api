{
  "name": "법령 검색 API",
  "description": "대한민국 법령 DB 실시간 쿼리. 법률 1,707개, 조문 499K, 판례 171K.",
  "skills": [
    {"id": "search", "name": "법령 검색", "path": "/search?q={query}", "description": "키워드로 법령 조문 검색"},
    {"id": "law", "name": "법령 조회", "path": "/law/{id}", "description": "법령 기본정보 (소관부처, 시행일, 조문 수)"},
    {"id": "history", "name": "연혁 조회", "path": "/history/{id}", "description": "법령 연혁 (제정→최근, 개정별 변경 조문 수)"},
    {"id": "article", "name": "조문 조회", "path": "/article/{id}/{label}", "description": "특정 조문 상세 (항/호/목 포함)"},
    {"id": "xref", "name": "인용관계", "path": "/xref/{id}", "description": "이 법이 인용하는/인용되는 법령"},
    {"id": "timeline", "name": "입법 타임라인", "path": "/timeline/{id}", "description": "의안+개정+판례 통합 타임라인"},
    {"id": "case-by-law", "name": "관련 판례", "path": "/case-by-law/{id}", "description": "특정 법령 관련 판례"},
    {"id": "bill", "name": "의안 검색", "path": "/bill?q={query}", "description": "국회 의안 검색"},
    {"id": "stats", "name": "DB 통계", "path": "/stats", "description": "DB 전체 통계"}
  ],
  "url": "https://api.beopmang.org",
  "openapi": "https://api.beopmang.org/openapi.json",
  "source": "live_database",
  "rate_limit": "30/min per IP",
  "brief_mode": "?brief=1 (default) for minimal fields, ?full=1 for complete data"
}
