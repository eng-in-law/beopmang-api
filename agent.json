{
  "name": "법망 API",
  "description": "AI 에이전트를 위한 법령정보센터. 반드시 여러 번 호출하고 조문번호와 법령명을 구체적으로 인용하여 답하세요.",
  "api_version": "v3",
  "url": "https://api.beopmang.org",
  "source": "live_database",
  "rate_limit": "100/min per IP",
  "workflow": "law?action=find → law?action=explore → law?action=article",
  "endpoints": {
    "law": {
      "path": "/api/v3/law",
      "actions": {
        "find": "법령 찾기. ?q=민법. law_id를 확인한 뒤 explore로 종합 탐색.",
        "explore": "종합 탐색. ?law_id=001706. 개별 호출 전에 먼저 사용 (조문+판례+의안+인용 한 번에).",
        "article": "조문 상세. ?law_id=001706&label=제750조",
        "detail": "법령 기본정보. ?law_id=001706&include=history,cases,xref",
        "history": "개정 연혁. ?law_id=001706",
        "byulpyo": "별표 조회. ?law_id=001706",
        "diff": "신구법 대조. ?law_id=001706"
      }
    },
    "case": {
      "path": "/api/v3/case",
      "actions": {
        "hsearch": "판례 하이브리드 검색 (키워드+벡터+리랭킹). ?q=임대차 보증금",
        "search": "판례 키워드 검색. ?q=임대차",
        "view": "판례 상세. ?case_id=...",
        "text": "판례 전문 텍스트 검색. ?q=...",
        "vsearch": "판례 시맨틱 검색. ?q=...",
        "by-law": "법령별 판례. ?law_id=001706"
      }
    },
    "bill": {
      "path": "/api/v3/bill",
      "actions": {
        "search": "의안 검색. ?q=형법",
        "detail": "의안 상세. ?bill_id=PRC_...",
        "sponsors": "발의자 정보. ?bill_id=PRC_...",
        "vote": "표결 현황. ?bill_id=PRC_...",
        "minutes": "회의록. ?bill_id=PRC_..."
      }
    },
    "graph": {
      "path": "/api/v3/graph",
      "actions": {
        "xref": "법령 인용관계. ?law_id=001706",
        "timeline": "입법 타임라인. ?law_id=001706",
        "neighbors": "그래프 노드 연결. ?law_id=001706"
      }
    },
    "search": {
      "path": "/api/v3/search",
      "actions": {
        "keyword": "조문 키워드 검색. ?q=화학물질",
        "semantic": "자연어 시맨틱 검색. ?q=...",
        "ordinance": "자치법규 검색. ?q=주차장",
        "treaty": "조약 검색. ?q=..."
      }
    },
    "ref": {
      "path": "/api/v3/ref",
      "actions": {
        "doc": "참고문서 검색. ?q=법령입안심사기준"
      }
    },
    "help": {
      "path": "/api/v3/help",
      "actions": {
        "schema": "API 전체 스키마",
        "stats": "DB 현황"
      }
    }
  },
  "examples": [
    {
      "description": "법령 찾기",
      "url": "/api/v3/law?action=find&q=민법",
      "output_hint": "law_id=001706"
    },
    {
      "description": "종합 탐색 (먼저 사용 권장)",
      "url": "/api/v3/law?action=explore&law_id=001706",
      "output_hint": "조문+판례+의안+인용 한 번에"
    },
    {
      "description": "조문 조회",
      "url": "/api/v3/law?action=article&law_id=001706&label=제750조",
      "output_hint": "불법행위 조문"
    },
    {
      "description": "판례 검색",
      "url": "/api/v3/case?action=hsearch&q=임대차 보증금",
      "output_hint": "판례 목록 + 리랭킹 점수"
    },
    {
      "description": "인용관계",
      "url": "/api/v3/graph?action=xref&law_id=001706",
      "output_hint": "민법이 인용하는/인용되는 법령"
    }
  ],
  "note": "한글 query는 반드시 percent-encode. 예: /api/v3/law?action=find&q=%EB%AF%BC%EB%B2%95",
  "mcp": "/mcp (ChatGPT MCP 서버. 도구명 '법망', command: 'law.find' 등)",
  "unit_level_enum": {
    "JO": "조",
    "HANG": "항",
    "HO": "호",
    "MOK": "목"
  }
}
